{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pypi push",
      "type": "shell",
      "command": "python3.12 -m build && twine upload dist/*",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    }
  ]
}
